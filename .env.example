# chat
RAG_CHAT_PROVIDER=zhipu
RAG_CHAT_MODEL=glm-5

# embedding
RAG_EMBED_PROVIDER=bailian
RAG_EMBED_MODEL=text-embedding-v4

# rerank
RAG_RERANK_PROVIDER=bailian
RAG_RERANK_MODEL=qwen3-rerank

# vector backend
RAG_VECTOR_BACKEND=faiss
RAG_FAISS_HYBRID_RANKER=weighted
RAG_FAISS_DENSE_WEIGHT=0.65
RAG_FAISS_SPARSE_WEIGHT=0.35
RAG_BM25_K1=1.5
RAG_BM25_B=0.75

# vendor keys
ZHIPU_API_KEY=your_zhipu_key
DASHSCOPE_API_KEY=your_dashscope_key
